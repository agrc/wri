{
  "name": "@ugrc/wri-functions",
  "private": true,
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "build": "npm run build:shared && npm run clean && tsc",
    "build:shared": "tsc -p shared/tsconfig.json",
    "build:shared:watch": "tsc -p shared/tsconfig.json --watch",
    "build:watch": "npm run build:shared:watch && tsc --watch",
    "build:watch:only": "tsc --watch",
    "check": "npm run build:shared && tsc -b && tsc -p tsconfig.tools.json --noEmit",
    "check:proxy": "node --import tsx/esm scripts/check-db-proxy.ts",
    "clean": "rimraf lib",
    "clean:shared": "rimraf shared/dist shared/tsconfig.tsbuildinfo",
    "db:migrate:latest": "node --import tsx/esm scripts/migrate.ts latest",
    "db:migrate:make": "node --import tsx/esm ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:make",
    "db:migrate:rollback": "node --import tsx/esm scripts/migrate.ts rollback",
    "db:migrate:status": "node --import tsx/esm scripts/migrate.ts status",
    "deploy": "firebase deploy --only functions",
    "lint": "eslint .",
    "logs": "firebase functions:log",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run serve",
    "start:local": "node --import tsx/esm scripts/start-local-dev.ts"
  },
  "dependencies": {
    "@arcgis/core": "^5.0.18",
    "@esri/arcgis-rest-feature-service": "^4.10.2",
    "@esri/arcgis-rest-request": "^4.10.2",
    "@google-cloud/cloud-sql-connector": "^1.10.0",
    "@ugrc/wri-shared": "file:./shared",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "knex": "^3.2.9",
    "ky": "^2.0.1",
    "tedious": "^19.2.1"
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "firebase-functions-test": "^3.4.1",
    "firebase-tools": "^15.15.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "22"
  }
}
